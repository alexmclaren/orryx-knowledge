# orryx-ai-automation MCP environment
ORRYX_PORT=9009
ORRYX_MCP_GATEWAY_URL=https://mcp.orryx.dev
ORRYX_GATEWAY_REGISTER=true
ORRYX_AUTH_MODE=bearer
ORRYX_AUTH_SECRET_NAME=orryx/ai-automation/api-token
ORRYX_AUDIT_SINK=cloudwatch
ORRYX_AUDIT_SINK_TARGET=/aws/orryx/ai-automation/audit
ORRYX_LOG_LEVEL=info