# orryx-risk-compliance MCP environment

# Port (defaults to 9001 per convention)
ORRYX_PORT=9001

# Gateway
ORRYX_MCP_GATEWAY_URL=https://mcp.orryx.dev
ORRYX_GATEWAY_REGISTER=true

# Auth — bearer (production) | mtls | none (local dev only)
ORRYX_AUTH_MODE=bearer
# When ORRYX_AUTH_MODE=bearer:
#   Prefers AWS Secrets Manager. Set ORRYX_AUTH_SECRET_NAME below.
#   Fallback: ORRYX_RISK_COMPLIANCE_TOKEN env var.
ORRYX_AUTH_SECRET_NAME=orryx/risk-compliance/api-token
ORRYX_RISK_COMPLIANCE_TOKEN=

# Audit sink — gateway | local-jsonl | cloudwatch | noop
ORRYX_AUDIT_SINK=cloudwatch
ORRYX_AUDIT_SINK_TARGET=/aws/orryx/risk-compliance/audit

# Log level
ORRYX_LOG_LEVEL=info
